# ── MAX Bot ────────────────────────────────────────────
MAX_BOT_TOKEN=your_max_bot_token_here
MAX_API_BASE=https://platform-api.max.ru

# ── Google Sheets авторизация ──────────────────────────
# Вариант 1: путь к JSON файлу сервисного аккаунта
GOOGLE_SA_JSON_PATH=./secrets/google_sa.json
# Вариант 2: содержимое JSON напрямую (для деплоя)
# GOOGLE_SA_JSON={"type":"service_account",...}

# ── Google Sheets ID таблиц ────────────────────────────
# Состояния пользователей (user_id, state, topic, timestamp...)
GSHEET_STATES_ID=REPLACE_ME
# Менеджеры (manager_name, telegram_id)
GSHEET_MANAGERS_ID=REPLACE_ME
# Клиенты ИНН (Наименование, ИНН, Договор, Менеджер)
GSHEET_CLIENTS_ID=REPLACE_ME
# Телефоны (user_id, number)
GSHEET_PHONES_ID=REPLACE_ME
# Логи (timestamp, user_id, action, result, comment)
GSHEET_LOGS_ID=REPLACE_ME
# Карта сообщений (manager_message_id, client_user_id...)
GSHEET_MSGMAP_ID=REPLACE_ME
# Корзина упаковки (уже настроено)
GSHEET_CART_ID=1lN1TtjXnpJJhP-SEfETWK-nPumFKoLHNpllLWkuUSkI
GSHEET_CART_GID=132342150

# ── Получатели (MAX user_id) ──────────────────────────
KLO_USER_ID=0
KLO_USER_ID_ROTATION=0
ACCOUNTANT_USER_ID=0
ACCOUNTANT2_USER_ID=0
SALES_USER_ID=0
GENERAL_CHAT_ID=0
ADMIN_USER_ID=0

# ── OpenRouter AI ──────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_SYSTEM_PROMPT=  # задаётся в prompts/system_prompt.txt

# ── Прочее ─────────────────────────────────────────────
USE_CART_SHEETS=1
LOG_TO_STDOUT=1
LOG_TO_SHEETS=0
# KLO_SPECIAL_DAYS=01-15,02-20,03-10  (MM-DD через запятую)
